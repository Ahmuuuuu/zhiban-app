# ============================================
# 智办环境变量配置模板
# 使用方法：cp .env.example .env ，然后填入真实值
# ============================================

# --- MySQL ---
MYSQL_ROOT_PASSWORD=your_mysql_root_password

# --- LLM API (DeepSeek / OpenAI) ---
API_KEY=sk-your-api-key-here

# --- JWT 认证 ---
JWT_KEY=your-jwt-secret-key-at-least-32-chars
ALGORITHM=HS256

# --- 讯飞 TTS (语音合成) ---
XF_APP_ID=
XF_API_KEY=
XF_API_SECRET=

# --- SMTP 邮件发送 (可选) ---
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your@qq.com
SMTP_PASS=your-smtp-auth-code
