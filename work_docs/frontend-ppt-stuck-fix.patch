+const parseMaybeJson = (value: any) => {
+  if (typeof value !== 'string') return value
+  try {
+    return JSON.parse(value)
+  } catch {
+    return value
+  }
+}
+
+const extractTaskResultList = (taskData: any) => {
+  let result = parseMaybeJson(taskData?.result ?? taskData?.resources ?? [])
+  if (result && typeof result === 'object' && !Array.isArray(result)) {
+    result = parseMaybeJson(result.resources ?? result.result ?? result.data ?? [])
+  }
+  return Array.isArray(result) ? result : []
+}
+
